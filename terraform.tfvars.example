# Proxmox API Configuration
proxmox_api_url           = "https://host:8006/api2/json"
proxmox_api_token_id      = "root@token"
proxmox_api_token_secret  = "token"
proxmox_api_insecure      = false   # Set to true if using self-signed certs

# Cluster Configuration
cluster_vip               = "10.25.150.10"

# Proxmox Server Configuration
proxmox_servers = {
  "host3" = {
    control_planes_count = 3      # 3 control-plane (master) nodes
    disk_storage_pool    = "rpool3"  # Ensure storage is created in rpool3
    network_bridge       = "vmbr0"   # Proxmox bridge (must be VLAN-aware if VLAN is used)
    node_labels          = {}
  }
}

# VLAN Tag (Optional)
proxmox_vlan_tag = 150          # Ensure VLAN ID is set to 150

# Storage Type (Optional)
proxmox_storage_type = "zfspool"  # 'zfspool' for ZFS storage, default is fine for rpool3

# Worker Nodes Configuration (3 workers)
worker_nodes = [
  {
    target_server = "host3"
    node_labels   = {}
    count         = 3          # 3 worker nodes
    cpu_cores     = 4
    memory        = 4
    disk_size     = 32
    data_disks    = []
  }
]
